# Optional — defaults to /api (Worker proxy to tanlabs-api)
# VITE_API_BASE=/api

# Google OAuth on login page (requires tanlabs-api Google OAuth config)
# VITE_AUTH_GOOGLE_ENABLED=true

# CSRF (match production API setting)
# VITE_AUTH_CSRF_PROTECTION_ENABLED=false

# Session watchdog interval (ms)
# VITE_SESSION_WATCHDOG_INTERVAL_MS=10000
